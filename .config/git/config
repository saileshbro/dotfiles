[init]
	defaultBranch = main
[core]
	editor = vim
[user]
	name = Sailesh Dahal
	email = saileshbro@gmail.com
	signingkey = ~/.ssh/id_ed25519.pub
[url "https://"]
	insteadOf = git://
[push]
	autoSetupRemote = true
[pull]
	rebase = true
[fetch]
	prune = true
[rebase]
	autoStash = true
[rerere]
	enabled = true
[diff]
	algorithm = histogram
[merge]
	conflictstyle = zdiff3
[column]
	ui = auto
[branch]
	sort = -committerdate
[commit]
	gpgsign = true
[alias]
	c = commit -s
	co = checkout -b
	lg = log --oneline --graph --decorate -20
	amend = commit --amend --no-edit -s
[gpg]
	format = ssh
[gpg "ssh"]
	allowedSignersFile = ~/.ssh/allowed_signers
[filter "lfs"]
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
	clean = git-lfs clean -- %f
[advice]
	skippedCherryPicks = false
