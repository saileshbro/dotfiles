alias copy='pbcopy'

# ── Directory listing (OMZ-equivalent, works with lsd alias) ──────────────────
alias ll='ls -lh'
alias la='ls -lAh'
alias l='ls -lah'
alias lsa='ls -lah'

# ── Directory navigation ───────────────────────────────────────────────────────
alias -g ...='../..'
alias -g ....='../../..'
alias -g .....='../../../..'
alias -g ......='../../../../..'
alias -- -='cd -'

# Show numbered directory stack
d() {
  if [[ -n $1 ]]; then
    dirs "$@"
  else
    dirs -v | head -10
  fi
}
compdef _dirs d

# mkdir + cd in one step (mirrors OMZ's `take`)
take() {
  mkdir -p "$@" && cd "${@:$#}"
}

alias flc='flutter clean'
alias flr='flutter run'
alias fpg='flutter pub get'
alias brw='dart run build_runner watch --delete-conflicting-outputs'
alias brb='dart run build_runner build --delete-conflicting-outputs'
alias brc='dart run build_runner clean'
alias clearpod='cd ios && rm -rf ~/Library/Caches/CocoaPods && rm -rf Pods && rm -rf ~/Library/Developer/Xcode/DerivedData/* && pod deintegrate && rm Podfile.lock && pod install --repo-update && cd ..'

alias onlyMain='git branch | grep -v "main" | xargs git branch -D'
alias onlyStaging='git branch | grep -v "staging" | xargs git branch -D'
alias cat='bat'
alias ls='lsd'
alias ping='gping'
alias spotx="bash <(curl -sSL https://raw.githubusercontent.com/SpotX-CLI/SpotX-Mac/main/install.sh) -huf"
alias nv='nvim'
alias npm='bun'
alias npx='bunx'
alias avd='emulator -list-avds'
