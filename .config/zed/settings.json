{
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "cursor": {
      "type": "registry",
    },
  },
  "context_servers": {
    "mcp-server-exa-search": {
      "enabled": true,
      "remote": false,
      "settings": {
        "exa_api_key": "cf5fa263-054b-4b33-93fe-b7930804f9bf",
      },
    },
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
      "settings": {
        "context7_api_key": "ctx7sk-b8b7f943-551d-4d60-b0c1-b0992cfff753",
      },
    },
  },
  "agent": {
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "search_web": {
          "default": "allow",
        },
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://pub\\.dev",
            },
            {
              "pattern": "^https?://github\\.com",
            },
          ],
          "default": "allow",
        },
        "terminal": {
          "always_allow": [
            {
              "pattern": "^ls\\b",
            },
            {
              "pattern": "^which\\s+flutterfire(\\s|$)",
            },
          ],
        },
      },
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
      "effort": "high",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "base_keymap": "VSCode",
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Zed (Default)",
  },
  "vim_mode": true,
  "theme": "Tinacious Design",
  "ui_font_family": "Operator Mono SSm Lig",
}
