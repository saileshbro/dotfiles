{
  "agent_servers": {
    "github-copilot-cli": {
      "type": "registry",
    },
    "gemini": {
      "type": "registry",
    },
    "cursor": {
      "type": "registry",
    },
  },
  "context_servers": {
    "mcp-server-exa-search": {
      "enabled": true,
      "remote": false,
    },
    "mcp-server-context7": {
      "enabled": true,
      "remote": false,
    },
  },
  "agent": {
    "tool_permissions": {
      "default": "confirm",
      "tools": {
        "web_search": {
          "default": "allow",
        },
        "fetch": {
          "always_allow": [
            {
              "pattern": "^https?://pub\\.dev",
            },
            {
              "pattern": "^https?://github\\.com",
            },
          ],
          "default": "allow",
        },
        "terminal": {
          "always_allow": [
            {
              "pattern": "^ls\\b",
            },
            {
              "pattern": "^which\\s+flutterfire(\\s|$)",
            },
          ],
        },
      },
    },
    "default_model": {
      "provider": "zed.dev",
      "model": "claude-sonnet-4-6",
      "enable_thinking": true,
      "effort": "high",
    },
    "favorite_models": [],
    "model_parameters": [],
  },
  "base_keymap": "VSCode",
  "icon_theme": {
    "mode": "system",
    "light": "Material Icon Theme",
    "dark": "Zed (Default)",
  },
  "vim_mode": true,
  "theme": "One Dark",
  "ui_font_family": "Operator Mono SSm Lig",
}
